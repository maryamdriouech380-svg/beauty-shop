<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>متجر التجميل والعناية العالمي | المنتجات الاحترافية</title>
    <!-- وسم الـ SEO العالمي للانتشار في جوجل -->
    <meta name="description" content="متجر عالمي متخصص في منتجات العناية بالشعر، العناية الشخصية، والمكملات الغذائية عالية الجودة.">
    <!-- تصميم عصري وسريع جداً متوافق مع الهواتف -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap');
        body { font-family: 'Tajawal', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <!-- الهيدر (رأس الموقع) -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <h1 class="text-2xl font-bold text-pink-600">✨ متجر الجمال والعناية العالمي</h1>
            <nav class="space-x-4 space-x-reverse hidden md:flex">
                <a href="#hair" class="hover:text-pink-600 font-medium">منتجات الشعر</a>
                <a href="#care" class="hover:text-pink-600 font-medium">العناية الشخصية</a>
                <a href="#supplements" class="hover:text-pink-600 font-medium">المكملات الغذائية</a>
            </nav>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8">
        
        <!-- ================= لوحة تحكم المسؤول لإضافة منتجاتك الخاصة ================= -->
        <section class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 max-w-2xl mx-auto mb-12">
            <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                📦 لوحة تحكم المسؤول (أضف منتجاتك وصورك الخاصة هنا)
            </h2>
            <form id="productForm" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700">عنوان المنتج</label>
                    <input type="text" id="title" required class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-pink-500 outline-none" placeholder="مثال: شامبو علاج تساقط الشعر">
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700">السعر ($)</label>
                        <input type="number" id="price" required class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-pink-500 outline-none" placeholder="29.99">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">قسم المنتج</label>
                        <select id="category" class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-pink-500 outline-none">
                            <option value="hair">منتجات الشعر</option>
                            <option value="care">العناية الشخصية</option>
                            <option value="supplements">المكملات الغذائية</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">رابط صورة المنتج الخاصة بك</label>
                    <input type="url" id="image" required class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-pink-500 outline-none" placeholder="انسخ رابط صورتك وضعه هنا">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">رابط الشراء المباشر للعميل</label>
                    <input type="url" id="buyLink" required class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-pink-500 outline-none" placeholder="رابط أمازون، أفلييت، أو الدفع الخاص بك">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">وصف المنتج (مهم جداً لجوجل وللذكاء الاصطناعي)</label>
                    <textarea id="description" rows="3" required class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-pink-500 outline-none" placeholder="اكتب تفاصيل الفوائد هنا ليجدها من يبحث عنها في جوجل..."></textarea>
                </div>
                <button type="submit" class="w-full bg-pink-600 hover:bg-pink-700 text-white font-bold py-3 rounded-lg transition duration-200">
                    ➕ نشر المنتج في موقعي فوراً
                </button>
            </form>
        </section>

        <!-- ================= أقسام عرض المنتجات الفعلي للمشترين ================= -->
        <div class="space-y-12">
            <!-- قسم الشعر -->
            <section id="hair">
                <h3 class="text-2xl font-bold text-gray-900 border-r-4 border-pink-600 pr-3 mb-6">🧴 منتجات الشعر</h3>
                <div id="hairContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>
            </section>

            <!-- قسم العناية الشخصية -->
            <section id="care">
                <h3 class="text-2xl font-bold text-gray-900 border-r-4 border-pink-600 pr-3 mb-6">🧼 العناية الشخصية</h3>
                <div id="careContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>
            </section>

            <!-- قسم المكملات الغذائية -->
            <section id="supplements">
                <h3 class="text-2xl font-bold text-gray-900 border-r-4 border-pink-600 pr-3 mb-6">💊 المكملات الغذائية</h3>
                <div id="supplementsContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>
            </section>
        </div>

    </main>

    <!-- البرمجة الخلفية للموقع لإدارة المنتجات والتتبع بالذكاء الاصطناعي -->
    <script>
        // دالة لجلب المنتجات المحفوظة في ذاكرة المتصفح للأبد (مجاناً وبدون سيرفر)
        let products = JSON.parse(localStorage.getItem('myProducts')) || [];

        function renderProducts() {
            document.getElementById('hairContainer').innerHTML = '';
            document.getElementById('careContainer').innerHTML = '';
            document.getElementById('supplementsContainer').innerHTML = '';

            if(products.length === 0) {
                const emptyHTML = `<p class="text-gray-400 text-sm col-span-full text-center py-4">الموقع فارغ حالياً، أضف منتجاتك الخاصة من لوحة التحكم في الأعلى.</p>`;
                document.getElementById('hairContainer').innerHTML = emptyHTML;
                document.getElementById('careContainer').innerHTML = emptyHTML;
                document.getElementById('supplementsContainer').innerHTML = emptyHTML;
                return;
            }

            products.forEach((product, index) => {
                const productHTML = `
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition duration-200 relative">
                        <button onclick="deleteProduct(${index})" class="absolute top-2 left-2 bg-red-500 text-white px-2 py-1 rounded text-xs hover:bg-red-600">حذف</button>
                        <img src="${product.image}" alt="${product.title}" class="w-full h-56 object-cover" onerror="this.src='https://placehold.co/600x400?text=خطأ+في+رابط+الصورة'">
                        <div class="p-5 space-y-3">
                            <span class="text-sm text-pink-600 font-bold bg-pink-50 px-2.5 py-1 rounded-full">💵 ${product.price} $</span>
                            <h4 class="text-lg font-bold text-gray-900 mt-2">${product.title}</h4>
                            <p class="text-sm text-gray-600 line-clamp-3">${product.description}</p>
                            <a href="${product.buyLink}" target="_blank" onclick="sendToAIPixel('${product.title}')" class="block text-center bg-gray-900 hover:bg-pink-600 text-white font-bold py-2.5 rounded-xl transition duration-200 mt-4">
                                🛒 اشترِ الآن
                            </a>
                        </div>
                    </div>
                `;
                document.getElementById(`${product.category}Container`).innerHTML += productHTML;
            });
        }

        // استقبال وحفظ المنتج الجديد
        document.getElementById('productForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const newProduct = {
                title: document.getElementById('title').value,
                price: document.getElementById('price').value,
                category: document.getElementById('category').value,
                image: document.getElementById('image').value,
                buyLink: document.getElementById('buyLink').value,
                description: document.getElementById('description').value,
            };

            products.push(newProduct);
            localStorage.setItem('myProducts', JSON.stringify(products)); // حفظ دائم في المتصفح
            renderProducts();
            document.getElementById('productForm').reset();
            alert("تم نشر منتجك الخاص وصورتك بنجاح!");
        });

        // دالة حذف منتج
        function deleteProduct(index) {
            if(confirm("هل أنت متأكد من حذف هذا المنتج؟")) {
                products.splice(index, 1);
                localStorage.setItem('myProducts', JSON.stringify(products));
                renderProducts();
            }
        }

        // 🧠 ربط الاستهداف بالذكاء الاصطناعي الخارجي
        function sendToAIPixel(productName) {
            console.log(`AI Signal: العميل مهتم بـ [${productName}]. إرسال البيانات لخوارزميات الإعلانات الذكية لمطاردته بالمنتج.`);
            // هنا يربط كود الـ Meta Pixel أو Google Ads Conversions API تلقائياً
        }

        // تشغيل الموقع
        renderProducts();
    </script>
</body>
</html>
